# =============================================================================
# MediaDock — Configuration
# =============================================================================
# Copiez ce fichier vers .env et renseignez vos valeurs :
#   cp .env.example .env
#
# En présence d'un fichier .env, MediaDock passe automatiquement en mode
# non-interactif. Sans .env, le mode interactif pose les questions.
# =============================================================================

# --- Serveur ---
SERVER_IP=192.168.1.185
SERVER_USER=root
SSH_KEY_PATH=~/.ssh/id_ed25519

# --- VPN ---
# Provider supporté par Gluetun (60+ providers)
# Liste complète : https://github.com/qdm12/gluetun-wiki
VPN_PROVIDER=nordvpn
VPN_TOKEN=xxxxxxxxxxxxxxxx

# --- Media Player ---
# Choix : emby | jellyfin | plex
MEDIA_PLAYER=jellyfin

# --- Stockage ---
# Mode : dedicated_disk | single_disk
STORAGE_MODE=dedicated_disk
# Disque data dédié (uniquement si STORAGE_MODE=dedicated_disk)
DATA_DISK=/dev/sdb

# --- Langue et qualité ---
LANGUAGE=fr
# Profil qualité Recyclarr : default | anime | custom
QUALITY_PROFILE=default

# --- Backup ---
# Fréquence : daily | weekly | monthly
BACKUP_SCHEDULE=weekly
BACKUP_PATH=/opt/mediadock/backups
